# ============================================================
# GROZEO .gitignore - For PHP Legacy Repos (Manage-Products, Grozeo-Bizadmin)
# ============================================================

# === CREDENTIALS & SECRETS (CRITICAL) ===
.env
.env.*
env
*.env
Web.config
Web.Debug.config
Web.Release.config
appsettings.json
appsettings.*.json
*.pfx
*.p12
*.key
*.pem

# === IDE & Editor ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# === Dependencies ===
vendor/
node_modules/
bower_components/

# === Compiled & Build ===
# NOTE: Do NOT ignore *.min.js / *.min.css — this legacy PHP app
# relies on pre-built vendor assets (Bootstrap, jQuery, etc.)
*.map

# === Logs ===
*.log
logs/
error_log
php_errors.log

# === Cache ===
cache/
*.cache

# === Uploads (user-generated content) ===
uploads/
tmp/
temp/

# === OS Files ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini
