<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="AgentMaster_Old.Master.cs" Inherits="RetalineProAgent.AgentMaster_Old" %>

<%@ Register Src="~/Controls/SideMenu.ascx" TagPrefix="uc1" TagName="SideMenu" %>
