<!DOCTYPE html>
<html lang="en">
<head runat="server">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Partner - Retaline</title>

<link runat="server" id="lnkFavIco" rel="shortcut icon" type="image/x-icon" />
  <!-- Google Font: Source Sans Pro -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="/Content/custom/plugins/fontawesome-free/css/all.min.css">
  <!-- Theme style -->
  <link rel="stylesheet" href="/Content/custom/dist/css/adminlte.min.css">
<link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- jQuery -->
<script src="/Content/custom/plugins/jquery/jquery.min.js"></script>
<!-- Bootstrap 4 -->
<script src="/Content/custom/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE App -->
<script src="/Content/custom/dist/js/adminlte.min.js"></script>
<script src="/Content/custom/plugins/sweetalert2/sweetalert2.min.js"></script>
    <script src="/Content/custom/plugins/toastr/toastr.min.js"></script>
    <script src="/Content/custom/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.min.js"></script>
<script type="text/javascript">

    var Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000
    });

    function showSuccess(msg) {
        $(document).Toasts('create', {
            class: 'bg-success',
            title: 'Success',
            subtitle: 'Assigned Order Picker',
            body: msg
        })
    }

    function showError(msg) {
        $(document).Toasts('create', {
            class: 'bg-danger',
            title: 'Error ',
            subtitle: ' Operation failed ',
            body: msg
        })
    }

    function showModal(strtitle, strbody, showActionButon=false) {
        $('#modal-default h4.modal-title').html(strtitle);
        $('#modal-default div.modal-body p').html(strbody);
        if (!showActionButon)
            $('#modal-default').find('#btnAction').hide();
        
        $('#modal-default').modal({ backdrop:'static'});
    }

</script>
    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body class="hold-transition sidebar-mini text-sm">
<!-- Site wrapper -->
<div class="wrapper">
    <form id="form1" runat="server">

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light text-sm">
    <!-- Left navbar links -->
      <uc1:HeaderNavigation runat="server" id="HeaderNavigation" />

    <!-- Right navbar links -->
    <ul class="navbar-nav ml-auto">
      <!-- Navbar Search -->
      <li class="nav-item">
        <a class="nav-link" data-widget="navbar-search" href="#" role="button">
          <i class="fa fa-search"></i>
        </a>
          <uc1:HeaderSearch runat="server" id="HeaderSearch" />
      </li>

      <!-- Messages Dropdown Menu -->
        <li class="nav-item dropdown">
        <uc1:HeaderMessagesDropdown runat="server" id="HeaderMessagesDropdown" />
        </li>
      <!-- Notifications Dropdown Menu -->
        <li class="nav-item dropdown">
        <uc1:HeaderNotificationDropdown runat="server" id="HeaderNotificationDropdown" />
        </li>

        <li class="nav-item dropdown user-menu">
            <uc1:HeaderUser runat="server" id="HeaderUser" />
      </li>



      <li class="nav-item">
        <a class="nav-link" data-widget="fullscreen" href="#" role="button">
          <i class="fa fa-expand-arrows-alt"></i>
        </a>
      </li>
        <asp:PlaceHolder ID="plsSwitchContainerBtn" runat="server">
      <li class="nav-item">
        <a class="nav-link" data-widget="control-sidebar" data-slide="true" href="#" role="button">
          <i class="fa fa-th-large"></i>
        </a>
      </li>
</asp:PlaceHolder>
    </ul>
  </nav>
  <!-- /.navbar -->
  <!-- Main Sidebar Container -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4">
    <!-- Brand Logo -->
    <a href="/" class="brand-link">
      <img src="<%= (String.IsNullOrEmpty(this.CurrentUser.LogoSmall)? (String.IsNullOrEmpty(this.CurrentUser.LogoImage)?"/content/images/markers/building-07.png":this.CurrentUser.LogoImage): this.CurrentUser.LogoSmall) %>" alt="" class="brand-image img-circle elevation-3" style="opacity: .8; max-width: 50px;">
      <span class="brand-text font-weight-light">&nbsp; <%= this.CurrentUser.StoreGroupName %></span>
    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar user (optional) -->
      <%--<div class="user-panel mt-3 pb-3 mb-3 d-flex">
        <div class="image">
          <img src="https://www.odocart.com/img/man.png" class="img-circle elevation-2" alt="User Image">
        </div>
        <div class="info">
          <a href="/profile" class="d-block"><%= this.CurrentUser.FullName %></a>
        </div>
          
          


      </div>--%>
        
      <!-- SidebarSearch Form -->
      <div class="form-inline mt-2">
        <div class="input-group" data-widget="sidebar-search">
          <input class="form-control form-control-sidebar" type="search" placeholder="Search" aria-label="Search">
          <div class="input-group-append">
            <button class="btn btn-sidebar">
              <i class="fa fa-search fa-fw"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Sidebar Menu -->
        <uc1:SideMenu runat="server" id="SideMenu" />      
      <!-- /.sidebar-menu -->
    </div>
    <!-- /.sidebar -->
  </aside>

  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
            <asp:ContentPlaceHolder ID="cpTitle" runat="server">
          <div class="col-sm-6">
            <h1><%= Page.Title %></h1>
          </div>
        </asp:ContentPlaceHolder>
        <asp:ContentPlaceHolder ID="cpBreadcrumb" runat="server">
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-item active"><%= Page.Title %></li>
            </ol>
          </div>
        </asp:ContentPlaceHolder>
        </div>
      </div><!-- /.container-fluid -->
    </section>

    <!-- Main content -->
    <section class="content">
<asp:ContentPlaceHolder runat="server" ID="cpMainContent"></asp:ContentPlaceHolder>
        
    </section>
    <!-- /.content -->
  </div>
  <!-- /.content-wrapper -->
  <!-- Control Sidebar -->
        <asp:PlaceHolder ID="plsSwitchContainer" runat="server">
  <aside class="control-sidebar control-sidebar-dark">
    <!-- Control sidebar content goes here -->
      <div class="p-3 control-sidebar-content" style=""><h5>Switch Store Group</h5>
          <hr class="mb-2">
          <uc1:SideBarRightMenu runat="server" plcSwitchButton="plsSwitchContainerBtn" plcSideMenuContainer="plsSwitchContainer" id="SideBarRightMenu" />
          
          <%--<div class="mb-4">
              <input type="checkbox" value="1" class="mr-1"><span>Dark Mode</span></div>
          <h6>Header Options</h6>
          <div class="mb-1"><input type="checkbox" value="1" class="mr-1"><span>Fixed</span></div>
          <div class="mb-1"><input type="checkbox" value="1" class="mr-1"><span>Dropdown Legacy Offset</span></div>
          <div class="mb-4"><input type="checkbox" value="1" class="mr-1"><span>No border</span></div>
          <h6>Sidebar Options</h6><div class="mb-1"><input type="checkbox" value="1" class="mr-1"><span>Collapsed</span></div><div class="mb-1"><input type="checkbox" value="1" class="mr-1">
              <span>Fixed</span></div><div class="mb-1"><input type="checkbox" value="1" checked="checked" class="mr-1"><span>Sidebar Mini</span></div>
              
              <a href="#">clear</a></select>--%>
          
      </div>

  </aside>
  <!-- /.control-sidebar -->
</asp:PlaceHolder>

        </form>
  <footer class="main-footer text-sm">
    <div class="float-right d-none d-sm-block">
      <b>Powered by</b> Velosit
