<%@ Master Language="C#" MasterPageFile="~/AgentMaster.Master" AutoEventWireup="true" CodeBehind="BusinessMaster.master.cs" Inherits="RetalineProAgent.Business.BusinessMaster" %>
<%--<%@ Register Src="~/Controls/HeaderNavigation.ascx" TagPrefix="uc1" TagName="HeaderNavigation" %>--%>
<%--<%@ Register Src="~/Business/Controls/HeaderNavigationBusiness.ascx" TagPrefix="uc1" TagName="HeaderNavigationBusiness" %>--%>
<%@ Register Src="~/Business/Controls/BusinessHeaderUser.ascx" TagPrefix="uc1" TagName="BusinessHeaderUser" %>
<%@ Register Src="~/Controls/ctrlMenuNavigation.ascx" TagPrefix="uc1" TagName="ctrlMenuNavigation" %>


<asp:Content ContentPlaceHolderID="matomoSite" runat="server">
    <!-- Matomo -->
    <script>
        var _paq = window._paq = window._paq || [];
        /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function () {
            var u = "<%= ConfigurationSettings.AppSettings.Get("MatomoUrl")%>";
            _paq.push(['setTrackerUrl', u + 'matomo.php']);
            _paq.push(['setSiteId', '72']);
            var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
            g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
        })();
    </script>
    <!-- End Matomo Code -->
    
</asp:Content>


<asp:Content ContentPlaceHolderID="head" runat="server">
    <asp:ContentPlaceHolder ID="cpNhead" runat="server"></asp:ContentPlaceHolder>
    <link href="../Content/css/custom/perfect-scrollbar.min.css" rel="stylesheet" />
    <script src="../Content/js/custom/perfect-scrollbar.jquery.min.js"></script>
</asp:Content>

<asp:Content ContentPlaceHolderID="cntUserHead" runat="server">
    <uc1:BusinessHeaderUser runat="server" id="BusinessHeaderUser1" />
</asp:Content>
<asp:Content ContentPlaceHolderID="cpHeaderNavigationAdmin" runat="server">
    <%--<uc1:HeaderNavigationBusiness runat="server" id="HeaderNavigationBusiness1" />--%>
    <uc1:ctrlMenuNavigation runat="server" ID="ctrlMenuNavigation" StartingNode="~/business" />
</asp:Content>
<asp:Content ContentPlaceHolderID="cpBreadcrumb" runat="server">
    <asp:ContentPlaceHolder ID="cpNBreadcrumb" runat="server"><li class="breadcrumb-item"><a href="/">Home</a></li></asp:ContentPlaceHolder>
</asp:Content>
<asp:Content ContentPlaceHolderID="cpTitle" runat="server">
    <asp:ContentPlaceHolder ID="cpNTitle" runat="server"></asp:ContentPlaceHolder>
</asp:Content>
<asp:Content ContentPlaceHolderID="cpMainContent" runat="server">
    <asp:ContentPlaceHolder ID="cpNMainContent" runat="server"></asp:ContentPlaceHolder>
</asp:Content>
