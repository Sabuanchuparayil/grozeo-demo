    <asp:Content ContentPlaceHolderID="cntProfileNav" runat="server"><a href="/tenant/profile" class="nav-link"><i class="fa-thin fa-user-vneck mr-2"></i> View Profile</a></asp:Content>
<asp:Content ContentPlaceHolderID="cpHeaderNavigationAdmin" runat="server">
