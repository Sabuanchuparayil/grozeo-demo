<asp:Content ContentPlaceHolderID="cphAdmin" runat="server">
    <asp:Panel runat="server" CssClass="desktoplogo" ID="pnlLogo" Visible="false">
            <asp:Image CssClass="desktoplogo_img" ID="logoImage" runat="server" />
        </asp:Panel>
        <div class="logotext d-flex align-items-center" runat="server" id="storeName" visible="false">
            
            <h2 data-toggle="tooltip" title="" class="" data-original-title='<%=  String.IsNullOrEmpty(this.CurrentUser.StoreGroupName) ? "My Store" : this.CurrentUser.StoreGroupName  %>'>
                <%=  String.IsNullOrEmpty(this.CurrentUser.StoreGroupName) ? "My Store" : this.CurrentUser.StoreGroupName  %>
            </h2>
        </div>
</asp:Content>
<asp:Content ContentPlaceHolderID="cntSwitchTenant" runat="server">

    <a class="pndjobs" title="Pending Jobs" href="/Tenant/PendingActions" id="pendingActionsCount" style="display:none;">
              <span class="d-none d-md-flex ml-0 ml-md-2 pl-0 pl-md-1">Pending Tasks</span>
              <span class="pndjobs_ount ml-0 ml-md-1" id="pendingCount"></span>
            </a>
    <script src="/Content/js/custom/home.js"></script>
    <script type="text/javascript">
        home.url.pendingActions = '/api/home/GetPendingTasks/0';
    </script>


                <% if (this.CurrentUser.PackageId < 2 && false)
                { %>
            <div class="public_site_url mr-3">
            <%--<a href="#" data-toggle="modal" data-target="#modalupgrade" class=" header-notification upgradelink px-3 py-2" title="Upgrade">
                <span class="mr-2 d-none d-lg-inline-block">Upgrade</span>
                <i class="fa-thin fa-arrow-up-big-small"></i>
            </a>--%>
            <a href="/tenant/subscription" class=" header-notification upgradelink px-3 py-2" title="Upgrade">
                <span class="mr-2 d-none d-lg-inline-block">Upgrade</span>
                <i class="fa-thin fa-arrow-up-big-small"></i>
            </a>
          </div>
            <% } %>

  <div class="public_site_url mr-3">
  <a href="/tenant/subscription" class=" header-notification upgradelink px-3 py-2" title="Subscription">
      <span class="mr-2 d-none d-lg-inline-block">Subscription</span>
      <i class="fa-thin fa-arrow-up-big-small"></i>
  </a>
</div>

            <div class="public_site_url mr-3">
            <a href="//<%= this.CurrentUser.PublicSiteUrl %>" target="_blank" class="header-notification website_view px-3 py-2" title="Go to Public Site">
                <%--<span class="mr-2 tx-16 d-none d-lg-inline-block">Go to Site</span>
                <i class="fa-thin fa-browser"></i>--%>

                <span class="gto_wrap">
                 <span class="mr-2 tx-16 d-none d-lg-inline-block">Go to Site</span>
                <i class="fa-thin fa-browser"></i>
              </span>
              <div class="liquid"></div>

            </a>
            <asp:PlaceHolder ID="plcPublicSiteUrlNav" Visible="false" runat="server">
            <div class="url_popover">
              <div class="closepopover">X</div>
            <div class="arrow"></div>
              <h3>Congratulations !!</h3>
              <p>Your online store is LIVE now. Click here to visit</p>
