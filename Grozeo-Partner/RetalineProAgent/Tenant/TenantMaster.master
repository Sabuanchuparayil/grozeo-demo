    <asp:PlaceHolder ID="plsSwitchContainerBtn" runat="server">
         <link href="/content/css/bootstrap-select.min.css" rel="stylesheet" />
<script src="/content/js/bootstrap-select.min.js"></script>
    <uc1:SideBarRightMenu runat="server" plcSwitchButton="plsSwitchContainerBtn" plcSideMenuContainer="plsSwitchContainer" id="SideBarRightMenu" />
</asp:PlaceHolder>

</asp:Content>
<asp:Content ContentPlaceHolderID="cntUserHead" runat="server">
