<%@ Master Language="C#" MasterPageFile="~/AgentMaster.Master" AutoEventWireup="true" CodeBehind="TenantMaster.master.cs" Inherits="RetalineProAgent.Tenant.TenantMaster" %>
<%@ Register Src="~/Controls/SideBarRightMenu.ascx" TagPrefix="uc1" TagName="SideBarRightMenu" %>
<%@ Register Src="~/Controls/HeaderNavigation.ascx" TagPrefix="uc1" TagName="HeaderNavigation" %>
<%@ Register Src="~/Controls/PopupUpgradeStore.ascx" TagPrefix="uc1" TagName="PopupUpgradeStore" %>
<%@ Register Src="~/Controls/HeaderUser.ascx" TagPrefix="uc1" TagName="HeaderUser" %>
<%@ Register Src="~/Controls/ctrlMenuNavigation.ascx" TagPrefix="uc1" TagName="ctrlMenuNavigation" %>


<asp:Content ContentPlaceHolderID="cntRibbonTopRight" runat="server">
    <asp:Panel runat="server" ID="pnlRibbon" Visible="false" CssClass="ribbon-corner ribbon-fold">
     
        <% if (!this.CurrentUser.CanCheckout)
            {  %>
                <a class="tx-white" href="/tenant/ManageBusinessInfo">Checkout Disabled</a>
        <% }
            else
            {  %>
        <a class="tx-white" href="/tenant/store/gst-add"><%= (ConfigurationManager.AppSettings.Get("VATType") == "2" ? "GST" : "VAT") %> Validation Pending</a>
        <% } %>
           <i class="fa-regular fa-circle-plus closeribbon tx-18 mr-2 ml-2" style="cursor: pointer;" onclick="$(this).closest('.ribbon-corner').hide()"></i>
    </asp:Panel>
</asp:Content>
<asp:Content ContentPlaceHolderID="matomoSite" runat="server">
    <!-- Matomo -->
    <script>
        var _paq = window._paq = window._paq || [];
        /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function () {
            var u = "<%= ConfigurationSettings.AppSettings.Get("MatomoUrl")%>";
            _paq.push(['setTrackerUrl', u + 'matomo.php']);
            _paq.push(['setSiteId', '73']);
            var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
            g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
        })();
    </script>
    <!-- End Matomo Code -->
    
</asp:Content>


