@inject SaasKit.Multitenancy.ITenant<Retaline.Core.ViewModel.Tenant.AppTenant> tenant;
@{
    string strthemeColour = "", strthemeLogo = "";
    if (tenant != null && tenant.Value != null)
    {
        if (!String.IsNullOrEmpty(tenant.Value.CustomColor))
            strthemeColour = tenant.Value.CustomColor;
        if (!String.IsNullOrEmpty(tenant.Value.LogoImage))
            strthemeLogo = tenant.Value.LogoImage;
    }

}
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Brew">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<link rel="apple-touch-icon" sizes="152x152" href="@(String.IsNullOrEmpty(strthemeLogo) ? "/images/LOGO.svg": strthemeLogo)" type="image/png">
<link rel="apple-touch-icon" sizes="167x167" href="@(String.IsNullOrEmpty(strthemeLogo) ? "/images/LOGO.svg": strthemeLogo)" type="image/png">
<link rel="apple-touch-icon" sizes="180x180" href="@(String.IsNullOrEmpty(strthemeLogo) ? "/images/LOGO.svg": strthemeLogo)" type="image/png">
<link rel="mask-icon" href="/images/LOGO.svg" color="#c7d300">
<link rel="apple-touch-startup-image"
      media="screen and (device-width: 320px) and (device-height: 568px) and (-webkit-device-pixel-ratio: 2) and (orientation: landscape)"
      href="/images/LOGO.svg" />

<link rel="stylesheet" href="~/customthemes/Gears/css/custom/gears_style.css" asp-append-version="true" />
<!-- theme font -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=PT+Sans+Caption:wght@400;700&family=PT+Sans:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">


