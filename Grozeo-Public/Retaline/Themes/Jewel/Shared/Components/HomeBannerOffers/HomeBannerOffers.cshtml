<div class="row">
    <div class="col-12">
        <div class="titlewrap">
            <h2 class="text-capitalize">Suggested stores near your location - <span></span>
                @if(User.Identity.IsAuthenticated){
                    <label class="change_store open-delivery-address">Change</label>
                }
                else
                {
                    <label class="change_store" data-bs-toggle="modal" data-bs-target="#search-address-modal">Change</label>
                }
            </h2>
        </div>
        <div class="store_list_wrap_sec d-flex flex-wrap row g-3 dvnearestbranch">
        </div>
    </div>
</div>

@if (User.Identity.IsAuthenticated)
{
    <script type="text/javascript">
        $(document).ready(function () {
            var cnfdeflatitude = '@_configuration["DefLatitude"]';
            var cnfdeflongitude = '@_configuration["DefLongitude"]';
            if (address.properties.deflatitude && address.properties.deflongitude && address.properties.deflatitude != cnfdeflatitude && address.properties.deflongitude != cnfdeflongitude
                && address.properties.deflatitude != '' && address.properties.deflongitude != '') {
                address.loadNearestStores(address.properties.deflatitude, address.properties.deflongitude);
            }
            else {
                address.loadNearestStores('-1', '-1');
            }

        });
    </script>
}
else
{

    <!-- Change location model-->

    <div class="modal fade address-modal-popup" id="search-address-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addressLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-body">
                    <div class="closepopup" data-bs-dismiss="modal" aria-label="Close"><img src="/images/icons/close.svg"></div>

                    <div class="editaddresspopupwrap">
                        <div class="editaddresswrapcard">
                            <div class="titlewrap">
                                <h4>Find Store</h4>
                            </div>
                            <div class="editadresswrap">
                                <h3>Search Address or <a href="#search-type_full_address">Type out address in full</a></h3>
                                <div class="adresssearchwrap">
                                        <div class="form-group">
                                            <div class="input-field">
                                                <label for="txt-location" class="form-label">Enter a location</label>
                                            <input type="text" id="search-txt-location" value="">
                                            </div>

                                            <div class="addressmap">
                                            <div id="searchmap"></div>
                                            </div>

                                            <div class="type_full_address" id="search-type_full_address">
                                                <div class="selectfilde lable-selectfilde d-flex justify-content-between flex-wrap flex-sm-nowrap">
                                                    <div class="input-btn text-end m-0 d-flex align-items-end ">
                                                        <button id="btn-search-address" class="btn SaveForDelivery" type="submit">Submit</button>
                                                    </div>
                                                </div><!--lable-selectfilde-->
                                            </div>

                                        </div>

                                </div>
                            </div>
                        </div>
                    </div><!--editaddresspopupwrap-->

                </div>
            </div>
        </div>
    </div>


    <!-- End of Change location model-->
    <script type="text/javascript">
        $(document).ready(function () {

            var cnfdeflatitude = '@_configuration["DefLatitude"]';
            var cnfdeflongitude = '@_configuration["DefLongitude"]';
            if (address.properties.deflatitude && address.properties.deflongitude && address.properties.deflatitude != cnfdeflatitude && address.properties.deflongitude != cnfdeflongitude
                && address.properties.deflatitude != '' && address.properties.deflongitude != '') {
                address.loadNearestStores(address.properties.deflatitude, address.properties.deflongitude);
            }
            else {
                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(showPosition, showError);
                } else {
                    $('.dvnearestbranch').html("<p>Your location is not accessible. Please use the change location button above to find the stores nearby.</p>");
                }
            }
        });

        function showPosition(position) {
            var latitude = position.coords.latitude;
            var longitude = position.coords.longitude;
            address.loadNearestStores(latitude, longitude);
        }

        function showError(error) {
            switch (error.code) {
                case error.PERMISSION_DENIED:
                //document.getElementById("demo").innerHTML = "User denied the request for Geolocation."
                //break;
                case error.POSITION_UNAVAILABLE:
                //document.getElementById("demo").innerHTML = "Location information is unavailable."
                //break;
                case error.TIMEOUT:
                //document.getElementById("demo").innerHTML = "The request to get user location timed out."
                //break;
                case error.UNKNOWN_ERROR:
                    //document.getElementById("demo").innerHTML = "An unknown error occurred."
                    $('.dvnearestbranch').html("<p>Your location is not accessible. Please use the change location button above to find the stores nearby.</p>");
                    break;
            }
        }
    </script>

}

