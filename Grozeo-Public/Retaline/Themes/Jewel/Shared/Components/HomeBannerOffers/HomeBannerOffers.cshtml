                                                    <a href="@Common.OfferUrl(Model[2].AdZoneDetails[0])">
                                                        <img title="@(Model[2].AdZoneDetails[0].AdvTitle)" src="@(Model[2].AdZoneDetails[0].AdvImageUrl)">
                                                    </a>
                                                </div>
                                            }
                                        </div>

                                        <!--adds_Vertical-->
                                    }
                                </div><!--adds_Verticalwrap-->
                                @if (Model.Count > 3 && Model[3].AdZoneDetails.Count > 0)
                                {
                                    <div class="adds_horsondal">
                                        <div class="adds_image">
