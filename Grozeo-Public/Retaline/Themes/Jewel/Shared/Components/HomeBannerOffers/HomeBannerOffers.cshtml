                    </div>


                    <!--gridsliderWrap-->

                    </div>*@


                        <!--swiper-slide-->

                    </div><!--swiper-wrapper-->
                </div><!--EveryDayOfferSlider-->
                <!--mobileEveryDayOffer-->

                <div class="mobileEveryDayOfferWrap d-md-block d-lg-none">
