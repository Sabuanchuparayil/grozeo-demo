@inject SaasKit.Multitenancy.ITenant<Retaline.Core.ViewModel.Tenant.AppTenant> tenant;
@model Retaline.Core.BusinessModel.UserDetails.User;
@using Retaline.Core.BusinessModel.UserDetails;
@using Microsoft.AspNetCore.Http;
@inject Retaline.Core.Services.HelperServices.IHttpHelperService HttpHelper

@{
	string addressTrigger = "";
    var curUser = Model;
	GuestData guestUser = HttpHelper.GuestUser;
	bool loggedIn = (curUser != null && !string.IsNullOrEmpty(curUser.Name) ? true : false);

}




<div class="serchsec_header-action">

	@if (curUser.PrimaryAddress != null)
	{
		<div class="header_adress">
			<div class="yourlocation delivery_adress_triger" data-bs-toggle="modal" data-bs-target="#adressDropdown">
				<i class="fa-thin fa-location-dot" aria-hidden="true"></i>
				<span class="typelocation">@curUser.PrimaryAddress.Type</span>
				<span class="locationaddrees">@curUser.PrimaryAddress.HouseName, @curUser.PrimaryAddress.City</span>
			</div>
		</div>

	}
	else
	{
		<div class="header_adress">
			<div class="yourlocation delivery_adress_triger" data-bs-toggle="modal" data-bs-target="@(User.Identity.IsAuthenticated ? addressTrigger : "#search-address-modal")">
				<i class="fa-thin fa-location-dot" aria-hidden="true"></i>
				<span class="typelocation">@(User.Identity.IsAuthenticated ? "" : "Guest")</span>
				<span class="locationaddrees">@(guestUser.GuestLocality != null ? guestUser.GuestLocality : "Select location")</span>
			</div>
		</div>
	}

	<div class="header-action-list">
		<div class="homebtn">
			<a href="index.html" class="header-action-icons active">
				<i class="fa-light fa-house" aria-hidden="true"></i>
				<span>Home</span>
			</a>
		</div>
		<div class="myaccount_drpdn">
			<a href="javascript:void(0)" class="header-action-icons mobile-profilemenu" onclick="OpenMobileMenu()">
				<i class="fa-light fa-user "></i>
				<span>Profile</span>
			</a>
			<a href="javascript:void(0)" class="header-action-icons trigerprofile dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
				<i class="fa-light fa-user "></i>
				<span>Profile</span>
			</a>
			<div class="dropdown-menu">
				<div class="profile_drdn_info">
					<h6>@(loggedIn ? curUser.Name : "Guest")</h6>
					<p>To access account and manage orders</p>
				</div>
				<ul class="dropdown-menu_list">
						@if (loggedIn)
					{
						<li>
							<a class="dropdown-item" href="/account">
								<i class="fa-light fa-bag-shopping me-2" aria-hidden="true"></i>
								My Orders
							</a>
						</li>
						<li>
							<a class="dropdown-item" href="/mywallet">
								<i class="fa-light fa-wallet me-2" aria-hidden="true"></i>
								My Wallet
							</a>
						</li>
						<li>
							<a class="dropdown-item" href="/address">
								<i class="fa-light fa-location-dot me-2" aria-hidden="true"></i>
								Manage Address
							</a>
						</li>
						<li>
							<a class="dropdown-item" href="/wishlist">
								<i class="fa-light fa-heart me-2" aria-hidden="true"></i>
								My Wishlist
							</a>
						</li>
						<li>
							<a class="dropdown-item" href="/contact">
								<i class="fa-light fa-headphones me-2" aria-hidden="true"></i>
								Support
							</a>
						</li>
						<li>
							<a class="dropdown-item" href="/install">
								<i class="fa-light fa-mobile me-2" aria-hidden="true"></i>
								Install App
							</a>
						</li>


						<li><hr></li>
					}

					<li>
						<a class="dropdown-item" href="/about-us">
							<i class="fa-light fa-bullhorn me-2" aria-hidden="true"></i>
							About Us
						</a>
					</li>
					<li>
						<a class="dropdown-item" href="/how-it-works">
							<i class="fa-light fa-scroll me-2" aria-hidden="true"></i>
							How it works
						</a>
					</li>
					<li>
						<a class="dropdown-item" href="/faq">
							<i class="fa-light fa-comments-question-check me-2" aria-hidden="true"></i>
							FAQ &amp; Support
						</a>
					</li>
					<li>
						<a class="dropdown-item" href="/terms-conditions">
							<i class="fa-light fa-memo me-2" aria-hidden="true"></i>
							Terms &amp; Conditions
						</a>
					</li>
					<li>
						<a class="dropdown-item" href="/return-refund-policy">
							<i class="fa-light fa-file-lines me-2" aria-hidden="true"></i>
							Privacy Policy
						</a>
					</li>
					<li>

					</li>
					<li><hr></li>
					@if (loggedIn)
					{
						<li>
							<a class="dropdown-item" href="/logout">
								<i class="fa-light fa-arrow-right-from-bracket me-2" aria-hidden="true"></i>
								Log out
							</a>
						</li>
					}
					else
					{
						<li>
							<a class="dropdown-item open-login-modal" href="javascript:void(0)">
								<i class="fa-light fa-arrow-right-from-bracket me-2" aria-hidden="true"></i>
								Sign In
							</a>
						</li>
					}

				</ul>
			</div>

		</div>


		<div class="hedr_wishlist">
			<a href="/wishlist" class="header-action-icons">
				<i class="fa-light fa-heart"></i>
				<span>Wishlist</span>
			</a>
		</div>

		<div class="CartMenu minicart_menu">

			<a href="javascript:void(0)" class="header-action-icons mycart_dropdown trigerCartMenu" onclick="cart.OpenMiniCart()" role="button" aria-label="Open Cart">
				<i class="fa-light fa-cart-flatbed-empty"></i>
				<span>Cart</span>
				<div class="cart-count">
					<span class="cartnubr cartcount">0</span>
				</div>
			</a>


			@await Component.InvokeAsync("HeaderCart")


		</div>

	</div>
</div>