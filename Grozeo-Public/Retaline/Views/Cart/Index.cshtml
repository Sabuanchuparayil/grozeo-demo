<script>
    cart.url.deleteCart = '@Url.Action("DeleteCartItem", "Cart")';
    cart.properties.isCartPage = true;


    $(document).ready(function () {
        // Check if any div inside .cart-listing has the class 'out-of-stock' or 'out_of_stock'
        if ($('.product-card.product_outofstock').length > 0) {
            // Find the button with class 'checkout_btn'
            var $checkoutBtn = $('.checkout_btn');
            var $autoRemoveBtn = $('.checkout_btn.auto_remove_items');
            // Modify the button if it exists
            if ($checkoutBtn.length > 0) {
                $checkoutBtn.addClass('hide')
                $autoRemoveBtn.removeClass('hide')
            }
        }
    });

    window.addEventListener('pageshow', function (event) {
        // Check if the page was loaded from the browser's cache (bfcache)
        if (event.persisted) { //runs only if browser navigation buttons are used
            $('.checkout_btn').removeClass('processing'); //Remove processing throbber
        }
    });
</script>

@if (deliveryMethod != null && deliveryMethod.HomeDelivery != null && deliveryMethod.CourierDelivery != null)
{

    <script>
        cart.properties.multiCourier = true;
    </script>


}

