@using Retaline.Core.Services.Wishlist;
@using Retaline.Core.Services.Cart;
@using Retaline.Core.BusinessModel.Wishlist;
@using Microsoft.AspNetCore.Http;
@using Retaline.Web.Service;
@inject IWishlistService _wishList;
@inject ICartService _cartService;
@inject IHttpContextAccessor _httpContextAccessor
@inject Microsoft.Extensions.Configuration.IConfiguration _configuration;
@model Retaline.Core.BusinessModel.Cart.CartData;
@inject SaasKit.Multitenancy.ITenant<Retaline.Core.ViewModel.Tenant.AppTenant> tenant;

@{
    if (Model.Cart == null)
        Model.Cart = new List<Retaline.Core.BusinessModel.Cart.CartDetails>();
    if (Model.PriceLabels == null)
        Model.PriceLabels = new List<Retaline.Core.BusinessModel.Cart.Checkout.CouponLabel>();
    if (Model.NearestItems == null)
        Model.NearestItems = new List<Retaline.Core.BusinessModel.Cart.CartNearestItem>();

    Retaline.Core.BusinessModel.Cart.DeliveryMethod deliveryMethod = null;
    if (Model != null && Model.Cart != null && Model.Cart.Count > 0)
    {
        var deldata = _cartService.CartDeliverymethod().Result;
        deliveryMethod = deldata.Data;
    }

    var multiDeliveryItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>();
    var courierItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>();
    var expressDelItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>();
    try { multiDeliveryItems = Model.Cart.Where(c => c.BranchTypeId < 3 && Model.NearestItems != null && Model.NearestItems.Any(nc => nc.StitID == c.CartProductId)).Select(c => c).ToList(); } catch { multiDeliveryItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>(); }
    try { courierItems = Model.Cart.Where(c => c.BranchTypeId < 3 && !multiDeliveryItems.Any(nc => nc.CartProductId == c.CartProductId)).Select(c => c).ToList(); } catch { courierItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>(); }
    try { expressDelItems = Model.Cart.Where(c => c.BranchTypeId == 3 && !multiDeliveryItems.Any(nc => nc.CartProductId == c.CartProductId)).Select(c => c).ToList(); } catch { expressDelItems = new List<Retaline.Core.BusinessModel.Cart.CartDetails>(); }
}

<div class="container">
    <div class="row">
        @if (multiDeliveryItems.Count > 0 || courierItems.Count > 0 || expressDelItems.Count > 0)
        {
            <div class="col-12">
                <ul class="order-processing_wrap">
                    <li class="d-flex justify-content-center flex-wrap odr_processing">
                        <div class="d-flex align-items-center justify-content-center processing-icon"></div>
                        <div class="processing-title w-100 text-center px-2">Review item</div>
                    </li>
                    <li class="d-flex justify-content-center flex-wrap">
                        <div class="d-flex align-items-center justify-content-center processing-icon"></div>
                        <div class="processing-title w-100 text-center px-2">Checkout</div>
                    </li>
                    <li class="d-flex justify-content-center flex-wrap">
                        <div class="d-flex align-items-center justify-content-center processing-icon"></div>
                        <div class="processing-title w-100 text-center px-2">Payment</div>
                    </li>
                </ul>

                <div class="titlewrap title_group">
                    <h2>Shopping cart</h2>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                @if (multiDeliveryItems.Count > 0)
                {
                    <div class="cart-listing_wrap">
                        <div class="sub_title">
                            <h6>Choose Delivery mode<i class="fa-light fa-circle-question ms-2" title="This items available in both Express Delivery and Courier so you can select convenient delivery mode"></i></h6>

                            <div class="empty-basket-wrap">
                                <a href="#" class="emptybasket" id="btnemptycart">
                                    <i class="fa-regular fa-trash-can"></i>Empty Basket
                                </a>
                            </div>
                        </div>

                        <div class="cart-listing">
                            @foreach (var item in multiDeliveryItems)
                                @await Component.InvokeAsync("CartItem", new Retaline.Web.Models.Cart.CartItem { Product = item, DeliveryProduct = Model.NearestItems.Where(p => p.StitID == item.CartProductId).FirstOrDefault(), DeliveryType = 3 })



                        </div>

                    </div>

                    <!--cart-listing_wrap-->
                }
                @if (expressDelItems.Count > 0)
                {
                    <div class="cart-listing_wrap">
                        <div class="sub_title">
                            <h6>Items Available in Express Delivery</h6>
                            <div class="empty-basket-wrap">
                                <a href="#" class="emptybasket" id="btnemptycart">
                                    <i class="fa-regular fa-trash-can"></i>Empty Basket
                                </a>
                            </div>
                        </div>
                        <div class="cart-listing">

                            @foreach (var item in expressDelItems)
                                @await Component.InvokeAsync("CartItem", new Retaline.Web.Models.Cart.CartItem { Product = item, DeliveryProduct = new Retaline.Core.BusinessModel.Cart.CartNearestItem { }, DeliveryType = 2 })


                        </div>
                    </div>

                }
                @if (courierItems.Count > 0)
                {
                    <div class="cart-listing_wrap">
                        <div class="sub_title">
                            <h6>Items Available in Courier Delivery</h6>
                            <div class="empty-basket-wrap">
                                <a href="#" class="emptybasket" id="btnemptycart">
                                    <i class="fa-regular fa-trash-can"></i>Empty Basket
                                </a>
                            </div>
                        </div>
                        <div class="cart-listing">

                            @foreach (var item in courierItems)
                                @await Component.InvokeAsync("CartItem", new Retaline.Web.Models.Cart.CartItem { Product = item, DeliveryProduct = new Retaline.Core.BusinessModel.Cart.CartNearestItem { }, DeliveryType = 2 })


                        </div>
                    </div>

                }

            </div>
            <div class="col-12 col-lg-4">
                <form method="post" id="frmsubmitcart" action="/checkout">

                    <div class="order-summery_wrap order-summery_cart">
                        <h5>Cart Summary</h5>
                        <ul class="order-summery_list">
                            @foreach (var labelprice in Model.PriceLabels)
                            {
                                if (labelprice.Label != "Total Payable" && labelprice.Value != "")
                                {
                                    <li class="cost-prod">
                                        <div class="order-summery_label">@labelprice.Label</div>
                                        <div class="order-summery_value">@Common.FormatCurrency(labelprice.Value, _configuration["CurrencySymbol"])</div>
                                    </li>
                                }
                            }
                        </ul>
                        @*  @foreach (var orderTotal in Model.PriceLabels.Where(l => l.Label == "Total"))
                    {
                    <div class="grand-total">
                    <div class="order-summery_label">Total Payable</div>
                    <div class="order-summery_value">@Common.FormatCurrency(orderTotal.Value, _configuration["CurrencySymbol"])</div>
                    </div>
                    break;
                    } *@
                        <div class="btn-field m-fixed-button">
                            @if (!User.Identity.IsAuthenticated)
                            {
                                <a href="javascript:void(0)" class="btn btn-primary checkout_btn  open-login-modal add-redirection" data-redirect="/cart">Login to check out</a>
                            }
                            else if (Model.Cart.Count > 0 && !Model.Cart.Any(c => c.CartSalesPrice <= 0) && tenant.Value.CanCheckout)
                            {
                                <button type="submit" class="btn btn-primary checkout_btn " value="Review and Checkout">Review to check out</button>
                                <a href="javascript:void(0)" class="btn btn-primary checkout_btn auto_remove_items hide" value="Remove Unavailable Items">Remove Unavailable Items</a>

                            }
                            else
                            {
                                <a href="@(Model.Cart.Count > 0 ? "/checkout" : "")" class="btn btn-primary checkout_btn " style="opacity: 0.2;" id="reviewBtn">Review to check out</a>
                            }

                            @if (Model.Cart.Any(c => c.PrescriptionRequired))
                            {
                                <input type="file" id="prescriptionupload" style="display:none" />
                            }
                            @if (deliveryMethod != null && deliveryMethod.HomeDelivery != null && deliveryMethod.CourierDelivery != null)
                            {
                                <input type="hidden" id="DeliveryType" />
                            }
                            else
                            {
                                <input type="hidden" id="DeliveryType" value="@(deliveryMethod != null && deliveryMethod.HomeDelivery != null ?"1":"2")" />
                            }
                        </div>
                        <div class="extr-info">
                            <p class="m-0">*Delivery charges may apply</p>
                        </div>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="col-12">
                <div class="emptycart_pg_wrap">
                    <div class="emptycart_pg_img">
                        <svg width="300" height="250" viewBox="0 0 2942 2258" fill="none" xmlns="http://www.w3.org/2000/svg">
