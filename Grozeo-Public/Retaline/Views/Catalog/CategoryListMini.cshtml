    $("div.categories .Collapsable").click(function () {

        $(this).parent().children().toggle();
        $(this).toggle();
        if ($(this).parent().children('ul').is(':hidden')) {
            $(this).children('span').text('+');
        }
        else {
            $(this).children('span').text('-');
        }
    });


