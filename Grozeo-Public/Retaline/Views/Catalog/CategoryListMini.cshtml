<style>
    .slick-track {
        margin-left: 0;
    }

    .category-list li {
        padding: 0px 1px;
        margin-bottom: 0px;
        text-align: center;
        width: 8.66666%;
        border: none;
        box-shadow: 0px 3px 6px 0px rgb(0 0 0 / 6%);
        padding-bottom: 0px;
        border-radius: 4px;
        margin-left: 24px;
    }

        .category-list li p {
            font-weight: 600;
            color: #425158;
            margin-bottom: 0px;
            font-size: 11px;
        }

        .category-list li .image {
            width: 100%;
            height: 83px;
            border-radius: 50%;
            margin: 0 auto 0px;
        }

    .section {
        padding: 10px 0px;
    }

    .mt-5, .my-5 {
        margin-top: 0px !important;
    }

    .product {
