    }

    .product .product-desc {
        padding-left: 10px;
        max-height: 40px;
    }

        .product .product-desc p {
            font-size: 11px;
            line-height: 20px;
        }

    .owlis img {
        width: auto;
        height: 120px;
        object-fit: contain;
        padding: 10px;
    }

    @@media (max-width: 767px) {
        .product-list li {
            width: 50%
        }
    }
