@using Retaline.Core.BusinessModel.Catalog;
@using Microsoft.AspNetCore.Http;
@model Retaline.Core.ViewModel.Catalog.CategoryItemViewModel

@{
}

<style>
    div.categories ul {
        list-style-type: none !important;
        overflow: unset !important;
        padding-left: 16px !important;
        max-height: none !important;
    }

    div.categories li {
        margin: 2px 0px;
        cursor: pointer;
        padding: 10px;
        border: solid 1px lightgray;
    }
        div.categories li ul li{border: none;}

        span.Collapsable {
            width: 100%;
        }
    div.categories li:hover {
        color: #303391;
    }

    span.Collapsable:hover {
        color: #303391;
    }

    ul.catmenu ul {
        display: none;
    }

    span.symbol {
        padding-right: 10px;
        width: 12px;
        display: inline-block;
    }

    @@media (min-width: 992px) {
        #main .product-list li {
            width: 25%;
        }

        #sidebar {
            height: 100%;
        }
    }

    div.categories a {
        color: #707070;
    }
</style>
<div id="content" class="bg-light ">
    <div class="container">

        <div class="row ">
            <div class="col-lg-12 mt-4 mres15">
                <div class="row">
                    <div class="col-xs-6 col-md-6   p-0">
                        <h4 class="mb-2">Shop by category </h4>
                    </div>
                </div>
            </div>
            @await Component.InvokeAsync("MyAccountSideMenu", "/categories")
            <div class="col-lg-4 mt-55">
                <div id="main">
                    <div class="widget categories" style="border: none; margin-bottom: 0px; padding-bottom: 0px;">
                        @*<h2>Shop by category</h2>*@
                        <ul class="catmenu">
                            @foreach (CategoryData item in Model.Categories)
                            {
                                <li id="cat_@item.CategoryId">
                                    <img src="@item.ImageUrl" style="width: 50px;" />
                                    <span class="Collapsable"><span class="symbol fright"> +</span>@item.CategoryName</span>
                                    <ul>
                                        @foreach (SubcategoryMaster data in item.Subcategories)
                                        {

                                        <li id="cat_@String.Format("{0}_{1}", item.CategoryId, data.CategoryId)">
                                            <img src="@data.ImageUrl" style="width: 50px;" />
                                            @*<a href="@String.Format("/pc/{0}/{1}/{2}", item.CategoryId, data.CategoryId, data.CategoryName)">@data.CategoryName</a>*@
                                            <span class="Collapsable"><span class="symbol fright"> +</span>@data.CategoryName</span>
                                            <ul>
            @foreach (SubCategory subCategory in data.Subcategory)
            {
                <li id="cat_@String.Format("{0}_{1}_{2}", item.CategoryId, data.CategoryId, subCategory.SubCategoryId)"><img src="@subCategory.SubCategoryImage" style="width: 50px;" /><a href="@String.Format("/pc/{0}/{1}/{2}/{3}", data.ParentCategory, data.CategoryId, subCategory.SubCategoryId, subCategory.SubCategoryName)">@subCategory.SubCategoryName</a></li>
            }
        </ul>
                                        </li>
                                        }
                                    </ul>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>


        </div>
    </div>
</div>


