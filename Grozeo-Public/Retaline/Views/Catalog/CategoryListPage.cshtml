                                {
                                    <a href="@(category.Categorylevel==4?String.Format("/vc/{0}/{1}", category.Id, category.CategoryName.Replace("/", "-")): String.Format("/pc/{0}/{1}/{2}", category.ParentCategoryId, category.Id, category.CategoryName.Replace("/", "-")))" class="catogery-slider__items swiper-slide">
                                        <div class="catogery-slider__img @((category.Categorylevel==4 && Model.VirtualCategoryId==category.Id) || (Model.CatId > 0 && category.Id == Model.CatId ) ?"active":"")">
                                            <img alt="category img" src="@(string.IsNullOrEmpty(category.ImageUrl)?"/images/p-no-image.png":category.ImageUrl)" onerror="this.src='/images/p-no-image.png'">
                                        </div>
                                                <div class="catogery-slider__title"><span>@category.CategoryName</span></div>
                                    </a>
                                }
                                else
                                {
                                    <a href="@(category.Categorylevel==4?String.Format("{3}/vc/{0}/{1}{2}", category.Id,category.CategoryName.Replace("/", "-"),ViewBag.UrlTypeId,ViewBag.UrlType): String.Format("{4}/pc/{0}/{1}{2}/{3}", category.ParentCategoryId, category.Id,ViewBag.UrlTypeId, category.CategoryName.Replace("/", "-"),ViewBag.UrlType))">
                                        <div class="catogery-slider__img  @((category.Categorylevel==4 && Model.VirtualCategoryId==category.Id) || (Model.CatId > 0 && category.Id == Model.CatId ) ?"active":"")">

                                            <img src="@(string.IsNullOrEmpty(category.ImageUrl)?"/images/p-no-image.png":category.ImageUrl)" alt="category" onerror="this.src='/images/p-no-image.png'">
                                        </div>
                                                <div class="catogery-slider__title"><span>@category.CategoryName</span></div>
                                    </a>
                                }

                            }
                        </div>
                    </div>
                    <div class="slideraction">
                        <div class="swiper-button-prev swiper-button"></div>
                        <div class="swiper-button-next swiper-button"></div>
                    </div>
                </div>

                }


                @if (Model.Products == null || Model.Products.Count < 1)
                {
                    @if (Model.IsOffersView && Model.ContentTypeId == 2 && Model.BrandId != -2)
                    {
                        <div>Sorry, the offer was expired or out of stock.</div>



                    }
                    <div class="text-center"><img src="/images/No_Results.jpg" /></div>
                }
                else
                {
                    <div class="products-collection-view product-itemview">

                        @await Component.InvokeAsync("ProductCard", Model.Products)
                        @if (Model.CurrentPage < Model.LastPage)
                        {
                            string loadMoreUrl = "";
                            if (Model.ContentTypeId == 2)
                            {
                                loadMoreUrl = $"/loadmoreoffers/{Model.BusinessTypeId}/{Model.RetailTypeId}/{(Model.CurrentPage + 1)}";
                            }
                            int curcatid = -1;
                            if (Model.ContentTypeId == 1 && Model.CategoryLevel > 0){
                                curcatid = (Model.CategoryLevel == 1 ? Model.ParentCatId : (Model.CategoryLevel == 2 ? Model.CatId : Model.SubCatId));
                            }
                            else if (Model.ContentTypeId == 6)
                            {
                                curcatid = Model.VirtualCategoryId;                               
                            }
                            <div class="btnautoloadmore product-card" navlink="@loadMoreUrl"
                                 contenttype="@Model.ContentTypeId" pagenum="@(Model.CurrentPage + 1)" subcatId="@(Model.IsBrandView ? -2 : ( Model.IsOffersView ? -1 : curcatid))" brandid="@(Model.IsBrandView ? Model.BrandId : "-1")" catlevel="@Model.CategoryLevel" searchkey="@(Model.ContentTypeId==5? Model.GroupId.ToString() : Model.CategoryName)"
                                 href="javascript:void(0)">
                                Load more Products
                            </div>
                        }
                    </div>

                    <!--product-itemview-->
                }

            </div>
        </div><!--groz-ctg-list-wrap-->
    </div><!--col-12-->
    @await Component.InvokeAsync("FloatingViewCart")
</div>
</div>
<script src="/js/custom/catalog.js"></script>
<script>

    master.url.offerLoadMore = '@offerUrl';
</script>
<script>
    var show_items = 9;
    var relatedCategoryCount = @Model.RelatedCategories?.Count ?? 0;

    const catogerysliderCategoryList = new Swiper('.catogeryslider__categoryList', {
        // Optional parameters
        slidesPerView: show_items,
        spaceBetween: 18,
        navigation: {
            nextEl: '.catogery-slider__categoryList .swiper-button-next',
            prevEl: '.catogery-slider__categoryList .swiper-button-prev',
        },

        breakpoints: {
            320: {  // when window width is >= 320px
                slidesPerView: "auto",
                spaceBetween: 10,
            },
            567: {  // when window width is >= 567px
                slidesPerView: "auto",
                spaceBetween: 10,
            },
            767: {  // when window width is >= 767px
                slidesPerView: 4,
                spaceBetween: 10,
            },
            850: {  // when window width is >= 991px
                slidesPerView: 5,
            },
            1099: { // when window width is >= 1199px
                slidesPerView: 5,
            },
            1200: { // when window width is >= 1200px
                slidesPerView: 7,
            },
        },
        on: {
            init: function () {
                if (relatedCategoryCount > show_items) {
                    setTimeout(() => {
                        $('.catogery-slider__categoryList .swiper-button-next').removeClass("swiper-button-disabled")
                    }, 1000); // small delay after Swiper finalizes
                }
            }
        }

    });
    document.addEventListener('DOMContentLoaded', function () {
        const categoriesLink = document.getElementById('categoriesLink');
       // const filterLink = document.getElementById('filterLink');
        const menuCategories = document.getElementById('menuCategories');
        const menuFilter = document.getElementById('menuFilter');

        // 2. Define the main toggle function
        function toggleContent(showElement, hideElement, activateLink, deactivateLink) {
            // Show the desired content div
            showElement.classList.remove('hide');
            // Hide the other content div
            hideElement.classList.add('hide');

            // Update active class on links
            activateLink.classList.add('active');
            deactivateLink.classList.remove('active');
        }
        // 3. Attach Event Listeners
        categoriesLink.addEventListener('click', function (event) {
            event.preventDefault(); // Prevent default link behavior (page jump/reload)
            toggleContent(menuCategories, menuFilter, categoriesLink, filterLink);
        });
        // filterLink.addEventListener('click', function (event) {
        //     event.preventDefault(); // Prevent default link behavior
        //     toggleContent(menuFilter, menuCategories, filterLink, categoriesLink);
        // });

        // Optional: Initial state setup (already handled by HTML and CSS, but good for dynamic content)
        // If you wanted to programmatically set the initial state:
        // toggleContent(menuCategories, menuFilter, categoriesLink, filterLink);
    });
</script>