@using Retaline.Core.BusinessModel.Catalog;
@using Retaline.Core.BusinessModel.Cart;
@using Microsoft.AspNetCore.Http;
@using Retaline.Core.Services.Wishlist;
@using System.Collections.Generic;
@using Retaline.Core.BusinessModel.Wishlist;
@model Retaline.Core.ViewModel.Catalog.CategoryItemViewModel
@inject IHttpContextAccessor _httpContextAccessor
@inject Retaline.Core.Services.Cart.ICartService _cartService;
@inject IWishlistService _wishList;
@inject Retaline.Core.Services.Authentication.ICustomAuthenticationService _customAuthenticationService;
@inject Retaline.Core.Services.Catalog.ICatalogService catalogService;

@{
    WishlistInfo _wishlistIds = _wishList.WishlistIds();
    if (_wishlistIds == null)
    {
        _wishlistIds = new WishlistInfo();
    }
    List<CartDetails> _cartItems = _cartService.CartItems().Result;
    if (_cartItems == null)
        _cartItems = new List<CartDetails>();

    string strCartItems = string.Join(",", _cartItems.Select(c => string.Join(",", c.Item.ItemMaster.Select(i => "{" + string.Format("\"id\":{0}, \"grp\":{1}, \"qty\":{2} ", i.StitID, i.StitFsiuid, c.CartOrderQty) + "}").ToArray())).ToArray());
    string strWishList = ""; //string.Join(",", _wishlistIds.Wishlist.Select(c => string.Join(",", c.ItemMaster.Select(i => "{" + string.Format("\"id\":{0}, \"grp\":{1}", i.StitID, i.StitFsiuid) + "}").ToArray())).ToArray());
    if (_wishlistIds != null && _wishlistIds.Wishlist != null)
    {
        strWishList = string.Join(",", _wishlistIds.Wishlist.Select(i => "{" + string.Format("\"id\":{0}, \"grp\":{1}", i.StitId, i.StitFsiUId) + "}").ToArray());
    }

    List<Retaline.Core.BusinessModel.Catalog.CategoryData> categories = new List<Retaline.Core.BusinessModel.Catalog.CategoryData>();
    try
    {
        categories = catalogService.FilteredCategories().Result;
    }
    catch
    {
        categories = new List<Retaline.Core.BusinessModel.Catalog.CategoryData>();
    }

    string strSelctedCatId = (Model.ParentCatId > 0 ? Model.ParentCatId.ToString() : "") + (Model.CatId > 0 ? "_" + Model.CatId : ""); // + (Model.SubCatId > 0 ? "_" + Model.SubCatId.ToString() : "");
    if (Model.CatId < 0 && Model.Categories.Where(c => c.Categorylevel == 3).Count() > 0)
        Model.CatId = Model.Categories.Where(c => c.Categorylevel == 3).FirstOrDefault().CategoryId;

    string offerUrl = Model.IsOffersView ? Retaline.Web.Service.Common.OfferUrl(new Retaline.Core.BusinessModel.Home.Advertisement.AdZoneInfo { AdvOffer = Model.OfferType, AdvOfferValue = Model.OfferTypeValue }, Model.CurrentPage.Value + 1) : ""; //Model.IsOffersView ? $"/offers/{Model.CurrentPage.Value + 1}" : "";
    bool hasCategoryId = (Model.ParentCatId > 0 || Model.CatId > 0 || Model.SubCatId > 0);

    var attributes = categories.Where(a => hasCategoryId && (
        // if sub category id is available then go with sub category id.
        (Model.SubCatId > 0 && a.Categorylevel == 3 && a.Id == Model.SubCatId)
        // Category attributes, Applicable only if subcategory id is <= 0
        || (Model.SubCatId <= 0 && a.Categorylevel == 2 && a.Id == Model.CatId)
        // Parent category attributes, if category id is <= 0
        || (Model.SubCatId <= 0 && Model.CatId <= 0 && a.Categorylevel == 1 && a.Id == Model.ParentCatId)
    )
        && a.Attributes != null).SelectMany(a => a.Attributes)
            .Where(a => a.Values != null).ToList();
    //var groupedAttributes = attributes.GroupBy(a => a.Name, a => a);

    string selectedAttributes = "";
    if (_httpContextAccessor.HttpContext.Request.Query.Any(r => r.Key == "_atr"))
        selectedAttributes = _httpContextAccessor.HttpContext.Request.Query.Where(r => r.Key == "_atr").FirstOrDefault().Value.FirstOrDefault();

}




<script type="text/javascript">
    function OpenFilterBy() {
        $(".filter-search-wrap").addClass('open-filter');
    }

    function closeFilterBy() {
        $(".filter-search-wrap ").removeClass('open-filter');
    }
    function filterResult() {
        var chkparams = '';
        $('input[type="checkbox"].ctlfilter:checked').each(function () {
            var checkboxValue = $(this).val();
            if (checkboxValue && checkboxValue != '')
                chkparams += (chkparams == '' ? '' : '|') + checkboxValue;
        });

        const url = new URL(location.href);
        url.searchParams.set('_atr', chkparams);
        location.assign(url.search);

    }

    $(document).ready(function () {
        cart.properties.cartItems = { "items": [@(new Microsoft.AspNetCore.Html.HtmlString(strCartItems)) ] }
        wishlist.properties.wishListItems = { "items": [@(new Microsoft.AspNetCore.Html.HtmlString(strWishList)) ] }

        // Add value to div when checkbox is checked
        $('input[type="checkbox"]').change(function () {
            var checkboxValue = $(this).attr("atrname");
            var checkboxId = $(this).attr("id")
            if ($(this).prop('checked')) {
                $('#resultDiv').append('<span id="' + $(this).attr('id') + '-data" class="badge text-dark tx-11 fw-normal me-1"> <span class="lh-sm">' + checkboxValue + '</span><button type="button" class="close p-0 bg-transparent border-0 text-white ms-1" style="top:1px; position: relative;" data-id="#' + $(this).attr('id') + '" ><i class="fa-solid fa-xmark tx-13"></i></button></span>');
            } else {
                // Remove value from div when checkbox is unchecked
                $('#resultDiv').find('#' + checkboxId + '-data').remove();
                console.log(checkboxValue);
            }
        });

        // Remove selected values when the button is clicked
        $('.clearallfilter').click(function () {
            $('#resultDiv').empty();
            $('.checkbox').prop("checked", false);
        });
        $(document).on("click", ".close", function () {
            //alert("test");
            var checkId = $(this).data("id");
            $(checkId).prop("checked", false);
            $(checkId + "-data").remove();
            console.log(checkId);
        });

        $('.filter_menu').click(function () {
            var menuId = $(this).data("target");
            $(".fltr_checkwrap").removeClass("active");
            $(menuId).addClass("active");
            $(".filter_menu").removeClass("active");
            $(this).addClass("active");
        });


    });

    cart.url.addToCart = '@Url.Action("AddToCart", "Cart")';
</script>

