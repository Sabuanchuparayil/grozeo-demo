@model Retaline.Core.ViewModel.Catalog.CategoryItemViewModel;
@using Retaline.Core.BusinessModel.Catalog;
@using Microsoft.AspNetCore.Http;
@inject IHttpContextAccessor _httpContextAccessor
@{
    Layout = null;

    string loadMoreUrl = "";
    if (Model.ContentTypeId == 2){
        loadMoreUrl = $"/loadmoreoffers/{Model.BusinessTypeId}/{Model.RetailTypeId}/{(Model.CurrentPage + 1)}";
    }
    else if(Model.ContentTypeId == -1 && Model.BranchId > 0)
    {
        loadMoreUrl = $"/br/loadmoreoffers/{Model.BranchId}/{(Model.CurrentPage + 1)}";
    }
    List<KeyValuePair<int, int>> variantGroup = new List<KeyValuePair<int, int>>();

}
@if(Model != null && Model.Products != null){

@* @foreach (Product item in Model.Products)
{
        if (variantGroup.Any(k => k.Key == item.VariantGroupId && k.Value == item.StoreGroupId))
            continue;

        if (item.VariantGroupId.Value > 0)
            variantGroup.Add(new KeyValuePair<int, int>(item.VariantGroupId.Value, item.StoreGroupId));
} *@
    @await Component.InvokeAsync("ItemMaster", Model.Products)


@if (Model.CurrentPage < Model.LastPage)
{
    if (Model.CurrentPage < 3 && Model.AutoLoadCount >= Model.CurrentPage)
    {
            <div class="btnautoloadmore product-card" navlink="@loadMoreUrl" contenttype="@Model.ContentTypeId" pagenum="@(Model.CurrentPage + 1)" subcatId="@(Model.IsOffersView ? -1 : Model.CurrentSubCatId)" brandid="@(Model.IsBrandView ? Model.BrandId : "-1")" catlevel="@Model.CategoryLevel" searchkey="@Model.CategoryName">Loading &nbsp;</div>
    }
    else
    {
        <div class="btnloadmore product-card add-btn align-middle btn-add-product-cart" navlink="@loadMoreUrl" pagenum="@(Model.CurrentPage + 1)" contenttype="@Model.ContentTypeId" subcatId="@(Model.IsOffersView ? -1 : Model.CurrentSubCatId)" brandid="@(Model.IsBrandView ? Model.BrandId : "-1")" catlevel="@Model.CategoryLevel" searchkey="@Model.CategoryName">Click to load more.. &nbsp;</div>
    }
}
}