@model List<Retaline.Core.BusinessModel.InfoPages.FaqContent>;
@{

}
<div class="container">

    <div class="row">
        @await Component.InvokeAsync("InfoPageSideMenu", "faq")

        <div class="col-12 col-lg-9">

            <div class="titlewrap title_group">
                <h2>FAQ</h2>
                <a href="/contact" class="Support-btn"><i class="fa-light fa-headset"></i><span>Get Support</span></a>
            </div>



            <div class="article-wrap">
                <div class="tab-content myordertab_content" id="myorder-tabContent">
                    <div class="faq-accordion-wrap">
                        <div class="accordion accordion-flush" id="faqaccordion">
                        @if (Model != null )
                            {
                                foreach (var content in Model)
                                {
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="faqaccordion@(content.Id)">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapse@(content.Id)" aria-expanded="false" aria-controls="flush-collapse@(content.Id)">
                                                @content.Title
                                            </button>
                                        </h2>
                                        <div id="flush-collapse@(content.Id)" class="accordion-collapse collapse" aria-labelledby="faqaccordion@(content.Id)" data-bs-parent="#faqaccordion">
                                            <div class="accordion-body">
                                                <p>@content.Description</p>
                                            </div>
                                        </div>
                                    </div>

                                }
                            if(Model.Count == 0)
                                {

                                    <h6>No Contents Available</h6>

                                }
                            }


                        </div>
                    </div>
                </div>

            </div><!--myorder-tabwrap-->


        </div><!--col-lg-9-->
    </div>
</div>

