@inject Microsoft.Extensions.Configuration.IConfiguration _configuration;
@inject SaasKit.Multitenancy.ITenant<Retaline.Core.ViewModel.Tenant.AppTenant> tenant;

@{
    var defLoginMethod = _configuration["DefaultLoginMethod"];
}
<!-- Login Modal Popup-->


<div class="modal fade login-modal" id="login-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="login-modalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">

			<div class="modal-body">
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				<div class="loginpopupcontent">
					<div class="logincontent">
						<div class="welcome_massage_wrap">
							<div class="welcome_title">
								<h5>Welcome to</h5>
								<div class="mrch_logo">
									@* @await Component.InvokeAsync("Logo") *@
									@{
										string strthemeLogo = "";
										if (tenant != null && tenant.Value != null)
										{
											if (!String.IsNullOrEmpty(tenant.Value.LogoImage))
												strthemeLogo = tenant.Value.LogoImage;
										}

									}
									@if (String.IsNullOrEmpty(strthemeLogo))
									{
										@if (tenant?.Value?.StoreId != "0" && !String.IsNullOrEmpty(tenant?.Value?.StoreId))
										{
											<span title="@tenant?.Value?.Name" class="logotext">
												<i class="fa-solid fa-store me-2" aria-hidden="true"></i>
												<span class="storname">@(tenant?.Value?.Name.Length > 15 ? Retaline.Web.Service.Common.ShrinkText(tenant?.Value?.Name, 15, false).Split(' ')[0] : tenant?.Value?.Name)</span>
											</span>
										}
										else
										{
											<span class="">
												<img src="/images/LOGO.svg" onerror="LogoIMGError(this)" alt="@tenant?.Value?.Name">
											</span>
										}
									}
									else
									{
										<span class="">
											<img class="desktoplogo_img" src="@(String.IsNullOrEmpty(strthemeLogo) ? "/images/LOGO.svg": strthemeLogo)" alt="@tenant?.Value?.Name" onerror="LogoIMGError(this)">
										</span>
									}
								</div>
							</div><!--welcome-->
							<div class="welcome_massage">
								<p>A member of Grozeo merchant network </p>
								<div class="logindisc">
									<ul>
										<li>Global network of neighbourhood retailers</li>
										<li>Unified login experience across merchants</li>
										<li>Single wallet transactions for easy payments</li>
										<li>Connect with your favourite stores anytime</li>
									</ul>
								</div>
							</div>
						</div>
