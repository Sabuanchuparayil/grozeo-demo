<script>
    $(document).ready(function () {
        $('#login-modal').on('hidden.bs.modal', function (e) {
            $('.mobile-control').removeClass('hide')
            $('#newacount_emailid_field').removeClass('hide')
            $('.otp-control').addClass('hide')
            $('.enterpassword_control').addClass('hide')
            $('.emaillogin_sec').addClass('hide')
            $('#phone-acc-create').addClass('hide')
            $('.create_account').addClass('hide')
            $('#mobileLogin').addClass('hide')
            $('#emailLogin-btn').removeClass('hide')
            $('.emaillogin-ip').removeClass('hide')
            $('.sociallogin').removeClass('hide')
        });

        $('#login-modal').on('hidden.bs.modal', function (e) {
            var inputElements = document.querySelectorAll('input');
            inputElements.forEach(function (inputElement) {
                if (inputElement.id) {
                    clearInputValue('#' + inputElement.id);
                }
            });
        });

        function clearInputValue(inputElement) {
            $(inputElement).val('');
        }
      
    });

   

</script>
<script>
	const NUM_INPUTS = 4; // Change this to scale the number of OTP boxes
	const otpContainer = document.getElementById("otpContainer");
	const hiddenOtpInput = document.getElementById("txtLoginOTP");

	function createOtpInputs(count) {
		otpContainer.innerHTML = "";

		for (let i = 0; i < count; i++) {
			const input = document.createElement("input");
			input.setAttribute("type", "number");
			input.setAttribute("maxlength", "1");
			input.setAttribute("id", "dynamic-otp" + i);
			input.classList.add("otp-input");

			// Input handling
			input.addEventListener("input", (e) => {
				const value = e.target.value.replace(/\D/g, ''); // Allow digits only
				if (value.length > 1) {
					handlePaste(value, i);
					return;
				}
				e.target.value = value;

				if (value && i < count - 1) otpContainer.children[i + 1].focus();
				updateHiddenField();
			});

			// Key navigation
			input.addEventListener("keydown", (e) => {
				if (e.key === "Backspace") {
					if (!e.target.value && i > 0) {
						otpContainer.children[i - 1].focus();
					}
				} else if (e.key === "ArrowLeft" && i > 0) {
					otpContainer.children[i - 1].focus();
				} else if (e.key === "ArrowRight" && i < count - 1) {
					otpContainer.children[i + 1].focus();
				}
			});

			// Paste handling
			input.addEventListener("paste", (e) => {
				e.preventDefault();
				const paste = e.clipboardData.getData("text").replace(/\D/g, '');
				handlePaste(paste, i);
			});

			otpContainer.appendChild(input);
		}

		otpContainer.children[0].focus();
		updateHiddenField();
	}

	function handlePaste(paste, startIndex) {
		const chars = paste.split("");
		for (let j = 0; j < chars.length && (startIndex + j) < NUM_INPUTS; j++) {
			const input = otpContainer.children[startIndex + j];
			input.value = chars[j];
		}

		const nextIndex = Math.min(startIndex + chars.length, NUM_INPUTS - 1);
		otpContainer.children[nextIndex].focus();

		updateHiddenField();
	}

	function updateHiddenField() {
		const otpValues = Array.from(otpContainer.querySelectorAll(".otp-input"))
			.map(input => input.value)
			.join('');
		if (hiddenOtpInput) {
			hiddenOtpInput.value = otpValues;
		}
	}

	createOtpInputs(NUM_INPUTS);

</script>
