				</a>
			</li>
			<li id="side-menu-wishlist">
				<a href="/wishlist">
					<i class="fa-light fa-heart me-2" aria-hidden="true"></i>
					My Wishlist
				</a>
			</li>
			<li id="side-menu-support">
				<a class="" href="/contact">
					<i class="fa-light fa-headphones me-2" aria-hidden="true"></i>
					Support
				</a>
			</li>
			<li id="side-menu-install">
				<a class="" href="/install">
					<i class="fa-light fa-mobile me-2" aria-hidden="true"></i>
					Install App
				</a>
			</li>
			<li id="side-menu-logout">
				<a class="" href="/logout">
					<i class="fa-light fa-arrow-right-from-bracket me-2" aria-hidden="true"></i>
					Log out
				</a>
			</li>
		</ul>
	</div>
</div><!--col-lg-3-->


<script type="text/javascript">
    $(function() {
		$("#side-menu-@Model > a").addClass("active");
	});
</script>
