@model string

<div class="col-12 col-lg-3">
	<div class="submenu-wrap">
		<ul class="submenu-wrap_list">
			<li id="side-menu-account">
				<a class="" href="/account">
					<i class="fa-light fa-bag-shopping me-2" aria-hidden="true"></i>
					My Orders
				</a>
			</li>
			<li id="side-menu-mywallet">
				<a class="" href="/mywallet">
					<i class="fa-light fa-wallet me-2" aria-hidden="true"></i>
					My Wallet
				</a>
			</li>
			<li id="side-menu-Address">
				<a class="" href="/Address">
					<i class="fa-light fa-location-dot me-2" aria-hidden="true"></i>
