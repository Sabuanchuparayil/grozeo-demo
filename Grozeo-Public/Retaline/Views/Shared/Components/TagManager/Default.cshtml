@model Retaline.Web.Models.Info.PluginModel

@if (Model != null && Model.TenantPlugins != null && Model.TenantPlugins.Count > 0)
{
    foreach(var plugin in Model.TenantPlugins)
    {
        if (plugin == null || plugin.TenantPlugins == null || plugin.TenantPlugins.Count <= 0)
            continue;

        if(Model.isHeader && plugin.Key == "MSCLARITY")
        {
            string clarityId = ""; try { clarityId = plugin.TenantPlugins.Where(p => p.Name == "MSCLARITYID").FirstOrDefault().Value; }catch{ clarityId = ""; }
            if (!String.IsNullOrEmpty(clarityId))
            {
                <script type="text/javascript">
                    (function(c,l,a,r,i,t,y){
                        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                    })(window, document, "clarity", "script", "@clarityId");
                </script>
            }
        }
        else if(plugin.Key == "GOOGLETAGMGR")
        {
            string _gTagMgrPluginId = ""; try { _gTagMgrPluginId = plugin.TenantPlugins.Where(p => p.Name == "GOOGLETAGMGRID").FirstOrDefault().Value; }catch{ _gTagMgrPluginId = ""; }
            if (!String.IsNullOrEmpty(_gTagMgrPluginId))
            {
                if (Model.isHeader)
                {
                    <!-- Google Tag Manager -->
                    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
                        })(window,document,'script','dataLayer','@_gTagMgrPluginId');</script>
                    <!-- End Google Tag Manager -->
                }
                else
                {
                    <!-- Google Tag Manager (noscript) -->
                    <noscript>
                        <iframe src="https://www.googletagmanager.com/ns.html?id=@_gTagMgrPluginId"
                            height="0" width="0" style="display:none;visibility:hidden"></iframe>
                    </noscript>
                    <!-- End Google Tag Manager (noscript) -->
                    
                }
            }            
        }
        else if (Model.isHeader && plugin.Key == "GoogleAnalytics")
        {
            string analyticsId = ""; try { analyticsId = plugin.TenantPlugins.Where(p => p.Name == "GOOGLEANALYTICSID").FirstOrDefault().Value; } catch { analyticsId = ""; }
            if (!String.IsNullOrEmpty(analyticsId))
            {
                <script async src="https://www.googletagmanager.com/gtag/js?id=@analyticsId"></script>
                <script>
                    window.dataLayer = window.dataLayer || [];
                    function gtag() { dataLayer.push(arguments); }
                    gtag('js', new Date());

                    gtag('config', '@analyticsId');
                </script>
            }
        }
        else if (plugin.Key == "MetaPixel")
        {
            string analyticsId = ""; try { analyticsId = plugin.TenantPlugins.Where(p => p.Name == "METAPIXELID").FirstOrDefault().Value; } catch { analyticsId = ""; }
            if (!String.IsNullOrEmpty(analyticsId))
            {
                if (Model.isHeader)
                {
                    <!-- Meta Pixel Code -->
                    <script>
                    !function(f,b,e,v,n,t,s)
                    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
                    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
                    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
                    n.queue=[];t=b.createElement(e);t.async=!0;
                    t.src=v;s=b.getElementsByTagName(e)[0];
                    s.parentNode.insertBefore(t,s)}(window, document,'script',
                    'https://connect.facebook.net/en_US/fbevents.js');
                    fbq('init', '@analyticsId');
                    fbq('track', 'PageView');
                        </script>
                    <!-- End Meta Pixel Code -->
                }
                else
                {
                    <noscript><img height="1" width="1" style="display:none"
                    src="https://www.facebook.com/tr?id=@(analyticsId)&ev=PageView&noscript=1"
                        /></noscript>

                }
            }
        }
        else if (Model.isHeader && plugin.Key == "TawkLive")
        {
            string tawkPropertyId = ""; try { tawkPropertyId = plugin.TenantPlugins.Where(p => p.Name == "TWALKLIVEID").FirstOrDefault().Value; } catch { tawkPropertyId = ""; }
            string tawkWidgetId = ""; try { tawkWidgetId = plugin.TenantPlugins.Where(p => p.Name == "TWALKWIDGETID").FirstOrDefault().Value; } catch { tawkWidgetId = ""; }

            if (!String.IsNullOrEmpty(tawkPropertyId) && !string.IsNullOrEmpty(tawkWidgetId))
            {
                if (Model.isHeader)
                {
                    <!--Start of Tawk.to Script-->
                    <script type="text/javascript">
                    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
                    (function(){
                    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
                    s1.async=true;
                    s1.src='https://embed.tawk.to/@(tawkWidgetId)/@(tawkPropertyId)';
                    s1.charset='UTF-8';
                    s1.setAttribute('crossorigin','*');
                    s0.parentNode.insertBefore(s1,s0);
                    })();
                    </script>
                    <!--End of Tawk.to Script-->                    
                }

            }
        }


    }

}
