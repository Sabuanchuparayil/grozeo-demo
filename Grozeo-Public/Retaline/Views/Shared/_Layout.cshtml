    <script type="text/javascript">
        var primaryAddr = '@(User.Identity.IsAuthenticated && curUser != null && curUser.PrimaryAddress == null ? (curUser.AddressCount > 0 ? "showaddr" : "newaddr") : "")';
        $(document).ready(function () {
            let observer;

            function startObserving() {
                const config = { childList: true, subtree: true };

                observer = new MutationObserver(() => {
                    const targetElement = document.querySelector('#address-modal'); // Check for ID
                    const shouldTrigger = !targetElement ||
                        (getComputedStyle(targetElement).display === 'none' && address.properties.logoutOnClose);

                    if (shouldTrigger) {
                        address.triggerAddAddress(true);
                    }

                });

                // Observe changes in the body (or any specific element)
                observer.observe(document.body, config);
            }

            // Function to stop observing changes
            function stopObserving() {
                if (observer) {
                    observer.disconnect();
                }
            }
            if (primaryAddr == 'newaddr') {
                address.properties.logoutOnClose = true;
                address.triggerAddAddress(true);
                startObserving();

            }
            else if (primaryAddr == 'showaddr') {
                showSelAddress();
                stopObserving();
                //address.properties.logoutOnClose = true;
                //address.showSelAddress(true);


                //$("#choose-location-modal").modal({ backdrop: 'static', keyboard: false });
                //$("#choose-location-modal").modal('show');
                //$("#choose-location-modal").find('.model-left').css('width', '100%');
            }
        });
    </script>


