            authentication.properties.captchaKey = '@captchaKey';
            authentication.url.fedRedirectUrl = '@(String.Format("{0}/[source]?redirect=https://{1}", _configuration["FedRedirectUrl"], _httpContextAccessor.HttpContext.Request.Host))';
            //authentication.properties.fedAuthFLKey = '@_configuration["FedAuthClientId"]';
            //authentication.properties.fedGoogleAuthClientId = '@_configuration["FedGoogleAuthClientId"]';

            cart.properties.currencySymbol = '@Html.Raw(_configuration["CurrencySymbol"])';
            //  cart.url.addToCart = '@Url.Action("AddToCart", "Cart")';
            address.url.addAddress = '@Url.Action("AddAddress", "Address")';
            master.properties.countryCode = '@countryCode';
